  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^12.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
