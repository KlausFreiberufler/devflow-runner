{
  "name": "@devflow/runner",
  "version": "0.2.2",
  "description": "Autonomous flow orchestration for DevFlow — spawns AI tools, verifies objectively, self-repairs on failure",
  "type": "module",
  "bin": {
    "devflow-runner": "./bin/devflow-run.js",
    "devflow-run": "./bin/devflow-run.js"
  },
  "main": "src/runner.js",
  "scripts": {
